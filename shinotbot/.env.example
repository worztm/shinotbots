# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# GitHub OAuth App (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=YOUR_CLIENT_ID_HERE
GITHUB_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# OAuth callback URL (must match GitHub OAuth App settings)
OAUTH_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Base URL of the Express OAuth server
OAUTH_BASE_URL=http://localhost:3000

# Polling interval in milliseconds (default: 60000 = 1 minute)
POLL_INTERVAL_MS=60000

# Path to SQLite database
DB_PATH=./data/shinotbot.db

# Express server port
WEB_PORT=3000
